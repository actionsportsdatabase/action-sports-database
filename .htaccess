# ── ACTION SPORTS DATABASE — BLUEHOST APACHE CONFIG ──────────────

# Force HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# www → non-www (use actionsportsdatabase.com as canonical)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Redirect alternate domains to primary
RewriteCond %{HTTP_HOST} ^(www\.)?actionsportsdb\.com$ [NC]
RewriteRule ^(.*)$ https://actionsportsdatabase.com/$1 [R=301,L]
RewriteCond %{HTTP_HOST} ^(www\.)?actionsportdatabase\.com$ [NC]
RewriteRule ^(.*)$ https://actionsportsdatabase.com/$1 [R=301,L]
RewriteCond %{HTTP_HOST} ^(www\.)?actionsportdb\.com$ [NC]
RewriteRule ^(.*)$ https://actionsportsdatabase.com/$1 [R=301,L]

# SPA routing — serve index.html for all non-file requests
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.html [L]

# ── CACHING ───────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML — short cache (content updates frequently)
  ExpiresByType text/html              "access plus 1 hour"
  # JS/CSS — longer cache (fingerprint if you update)
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType text/css              "access plus 7 days"
  # Images
  ExpiresByType image/png             "access plus 30 days"
  ExpiresByType image/svg+xml         "access plus 30 days"
</IfModule>

# ── COMPRESSION ───────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

# ── SECURITY HEADERS ──────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── BLOCK SENSITIVE FILES ─────────────────────────────────────────
<FilesMatch "\.(log|env|git|bak|sh)$">
  Order allow,deny
  Deny from all
</FilesMatch>
